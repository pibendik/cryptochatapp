DOMAIN=chat.example.com
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=chatapp
DATABASE_URL=postgresql://chatapp:change_me_in_production@postgres:5432/chatapp
RUST_LOG=info
SERVER_ADDR=0.0.0.0:8080
# Set to "production" to enable startup safety checks (e.g. hard-abort if the
# allowlist is empty and BOOTSTRAP_ADMIN_KEY is unset).
APP_ENV=production
# Comma-separated list of allowed CORS origins. Empty = deny all cross-origin requests.
# Example: ALLOWED_ORIGINS=https://chat.example.com,tauri://localhost
ALLOWED_ORIGINS=
# Session TTL in seconds (default: 14400 = 4 hours).
SESSION_TTL_SECS=14400
# Bootstrap admin key (hex-encoded Ed25519 public key, 64 chars).
# If set and the public_key_allowlist table is empty on startup, this key is
# inserted automatically so the first admin can reach POST /admin/allowlist.
# Leave empty in production once real keys have been added via the ceremony.
BOOTSTRAP_ADMIN_KEY=
# Push notifications — all optional; leave blank to disable the platform.
# If disabled, offline messages are still queued and delivered on reconnect.
FCM_SERVER_KEY=           # Firebase server key (from Firebase console → Project Settings → Cloud Messaging)
APNS_KEY_PATH=            # Absolute path to .p8 APNs auth key (from Apple Developer portal)
APNS_KEY_ID=              # 10-char key ID from Apple Developer portal
APNS_TEAM_ID=             # 10-char Apple team ID
APNS_BUNDLE_ID=           # com.example.cryptochatapp
